{
  "name": "ai-study-rooms",
  "version": "0.0.1",
  "author": "Ezaz Ahmed",
  "devDependencies": {
    "turbo": "^2.9.14",
    "typescript": "5.9.2",
    "prettier": "^3.7.4",
    "eslint": "^9.0.0",
    "lint-staged": "^15.0.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "husky": "^9.0.0"
  },
  "description": "A platform where learners join dedicated real-time study rooms for their courses, featuring group chat, live sessions, and an AI tutor",
  "engines": {
    "node": ">=18",
    "bun": ">=1.3.11"
  },
  "keywords": [
    "education",
    "study",
    "ai",
    "real-time",
    "chat",
    "tutor"
  ],
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,md,css}": [
      "prettier --write"
    ]
  },
  "packageManager": "bun@1.3.11",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "check-types": "turbo run check-types",
    "prepare": "husky"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
